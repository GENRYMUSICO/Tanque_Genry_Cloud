# --- 4. MOTOR HÍBRIDO ---

class MotorGenryCentinela:
    def __init__(self):
        self.lista_negra = []
        if os.path.exists("hashes_virus.txt"):
            with open("hashes_virus.txt", "r") as f: self.lista_negra = [l.strip() for l in f if l.strip()]

    def patrullar(self):
        """Escaneo Híbrido: Hashes + Comportamiento[cite: 6]"""
        while True:
            for p in psutil.process_iter(['name', 'exe']):
                try:
                    # Detección por Hash[cite: 6]
                    if p.info['exe'] and self.calcular_hash(p.info['exe']) in self.lista_negra:
                        p.terminate()
                        self.reportar_ataque(p.info['name'], "VIRUS CONOCIDO")
                    # Detección Heurística[cite: 6]
                    sospechoso, motivo = es_comportamiento_sospechoso(p)
                    if sospechoso: self.reportar_ataque(p.info['name'], motivo)
                except: continue
            time.sleep(5)

    def reportar_ataque(self, nombre, motivo):
        adn = obtener_adn_maquina()
        log = f"\n[ATAQUE DETECTADO] {datetime.datetime.now()} | {nombre} | MOTIVO: {motivo} | ADN: {adn}"
        actualizar_archivo_nube("reporte_forense.txt", log)
        gestionar_persistencia_30_dias()

    def calcular_hash(self, ruta):
        h = hashlib.md5()
        try:
            with open(ruta, 'rb') as f:
                for chunk in iter(lambda: f.read(4096), b""): h.update(chunk)
            return h.hexdigest()
        except: return None
